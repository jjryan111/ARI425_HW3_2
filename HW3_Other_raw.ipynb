    "def parse_response(response):\n",
    "    if isinstance(response, list):\n",
    "        return response\n",
    "    if isinstance(response, str):\n",
    "        translated_responses = []\n",
    "        try:\n",
    "            results = ast.literal_eval(response)\n",
    "            for response in results:\n",
    "                translated_responses = label_mappings[response]\n",
    "            return translated_responses\n",
    "        except (ValueError, SyntaxError):\n",
    "            return []\n",
    "    return []\n",
    "\n",
    "def make_llm_results_dfs(results):\n",
    "    cols = list(range(28)) + list(range(100, 128))\n",
    "    ollama_df = pd.DataFrame(0, index=list(results.keys()), columns=cols)\n",
    "    groq_df = pd.DataFrame(0, index=list(results.keys()), columns=cols)\n",
    "    for ident, row in results.items():\n",
    "        # Parse the response string into an actual list\n",
    "        ollama_preds = [0] #parse_response(row['ollama']) \n",
    "        groq_preds = parse_response(row['groq'])\n",
    "        \n",
    "        # Map predicted emotion strings to 100+ int columns\n",
    "        for pred in ollama_preds:\n",
    "            try:\n",
    "                ollama_df.at[ident, 100 + inverted_labels[pred]] = 1\n",
    "                \n",
    "            except KeyError:\n",
    "                continue\n",
    "                \n",
    "        for pred in groq_preds:\n",
    "            try:\n",
    "                groq_df.at[ident, 100 + inverted_labels[pred]] = 1\n",
    "                \n",
    "            except KeyError:\n",
    "                continue\n",
    "            \n",
    "        # Map ground truth labels to 0-27 int columns\n",
    "        for label in row['labels']:\n",
    "            if label in cols:\n",
    "                ollama_df.at[ident, label] = 1\n",
    "                groq_df.at[ident, label] = 1\n",
    "    \n",
    "    return ollama_df, groq_df"
   ]
  },
