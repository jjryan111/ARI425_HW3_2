    "def get_f1_no_zeros(df):\n",
    "    truth = df[list(range(28))].values\n",
    "    preds = df[list(range(100, 128))].values\n",
    "\n",
    "    # Drop rows where both truth and preds are all zeros\n",
    "    mask = (truth.sum(axis=1) > 0) | (preds.sum(axis=1) > 0)\n",
    "    truth = truth[mask]\n",
    "    preds = preds[mask]\n",
    "\n",
    "    macro_f1  = f1_score(truth, preds, average='macro', zero_division=0)\n",
    "    micro_f1  = f1_score(truth, preds, average='micro', zero_division=0)\n",
    "    exact_match = (truth == preds).all(axis=1).mean()\n",
    "\n",
    "    print(f\"Rows evaluated:       {mask.sum()} / {len(mask)}\")\n",
    "    print(f\"Exact match accuracy: {exact_match:.4f}\")\n",
    "    print(f\"Macro F1:             {macro_f1:.4f}\")\n",
    "    print(f\"Micro F1:             {micro_f1:.4f}\")"
