    "def match_percentage_per_label(df):\n",
    "    results = {}\n",
    "    for i in range(28):\n",
    "        truth_col = i\n",
    "        pred_col = i + 100\n",
    "        \n",
    "        truth_mask = df[truth_col] == 1\n",
    "        total = truth_mask.sum()\n",
    "        matches = ((df[truth_col] == 1) & (df[pred_col] == 1)).sum()\n",
    "        \n",
    "        label_name = label_mappings[i]\n",
    "        results[label_name] = matches / total * 100 if total > 0 else None\n",
    "\n",
    "    return pd.Series(results)\n",
    "\n"
   ]
